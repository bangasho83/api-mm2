    },
    "/api/keyword-sim": {
      "post": {"tags": ["Keywords"], "summary": "Simulate keyword performance", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"keyword": {"type": "string"}, "data": {"type": "object"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
