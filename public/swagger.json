      "post": {"tags": ["Billing"], "summary": "Add billing contract", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["organizationId"], "properties": {"organizationId": {"type": "string"}, "contractData": {"type": "object"}}}}}}, "responses": {"201": {"description": "Created"}}}
    },
    "/api/billing/rate-card": {
      "get": {"tags": ["Billing"], "summary": "Get rate card", "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/payment-info": {
      "get": {"tags": ["Billing"], "summary": "Get payment information", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/has-payment": {
      "get": {"tags": ["Billing"], "summary": "Check if organization has payment method", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/link-stripe": {
      "post": {"tags": ["Billing"], "summary": "Link Stripe account", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["organizationId"], "properties": {"organizationId": {"type": "string"}, "stripeCustomerId": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/ingest": {
      "post": {"tags": ["Billing"], "summary": "Ingest billing data", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"data": {"type": "object"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/combined-analytics": {
      "get": {"tags": ["Analytics"], "summary": "Get combined analytics data", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "brandId", "in": "query", "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
