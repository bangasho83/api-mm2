{
  "openapi": "3.0.0",
  "info": {
    "title": "MetrixMate API",
    "description": "API documentation for MetrixMate social media analytics and marketing platform",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "url": "https://api-mm2.vercel.app"
    }
  },
  "servers": [
    {
      "url": "https://api-mm2.vercel.app",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Image Generation",
      "description": "AI-powered image generation endpoints"
    },
    {
      "name": "Moodboard",
      "description": "Moodboard collection management"
    },
    {
      "name": "Meta Ads",
      "description": "Meta (Facebook/Instagram) advertising analytics"
    },
    {
      "name": "Analytics",
      "description": "Google Analytics 4 data endpoints"
    },
    {
      "name": "Billing",
      "description": "Billing and subscription management"
    },
    {
      "name": "Organizations",
      "description": "Organization management"
    },
    {
      "name": "Brands",
      "description": "Brand management"
    }
  ],
  "paths": {
    "/api/image-gen": {
      "get": {
        "tags": ["Image Generation"],
        "summary": "List generated images",
        "description": "Retrieve a list of generated images from the creativeGen collection with optional filters",
        "parameters": [
          {
            "name": "organizationId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Organization ID"
          },
          {
            "name": "brandId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by brand ID"
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by user ID"
          },
          {
            "name": "model",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["Imagen4", "Nano Banana", "Nano Banana Pro", "Flux-kontext"]
            },
            "description": "Filter by AI model"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25,
              "minimum": 1,
              "maximum": 100
            },
            "description": "Number of items per page"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "organizationId": {
                      "type": "string"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "totalCount": {
                      "type": "integer"
                    },
                    "page": {
                      "type": "integer"
                    },
                    "pageSize": {
                      "type": "integer"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "imageUrl": {
                            "type": "string"
                          },
                          "prompt": {
                            "type": "string"
                          },
                          "model": {
                            "type": "string"
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Image Generation"],
        "summary": "Generate images",
        "description": "Generate AI images using various models (Imagen4, Nano Banana, Flux, etc.)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt", "organizationId"],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Text prompt for image generation"
                  },
                  "organizationId": {
                    "type": "string",
                    "description": "Organization ID"
                  },
                  "brandId": {
                    "type": "string",
                    "description": "Brand ID"
                  },
                  "userId": {
                    "type": "string",
                    "description": "User ID"
                  },
                  "model": {
                    "type": "string",
                    "enum": ["imagen4", "banana-text", "banana-pro-text", "banana-image", "banana-pro-image", "flux-kontext"],
                    "default": "imagen4",
                    "description": "AI model to use"
                  },
                  "aspect_ratio": {
                    "type": "string",
                    "enum": ["1:1", "16:9", "9:16", "3:4", "4:3"],
                    "default": "1:1",
                    "description": "Image aspect ratio"
                  },
                  "num_images": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 4,
                    "default": 1,
                    "description": "Number of images to generate"
                  },
                  "negative_prompt": {
                    "type": "string",
                    "description": "Negative prompt (what to avoid)"
                  },
                  "brandGuideline": {
                    "type": "string",
                    "description": "Brand guidelines"
                  },
                  "creativeGuideline": {
                    "type": "string",
                    "description": "Creative guidelines"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Images generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "images": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "seed": {
                      "type": "integer"
                    },
                    "requestId": {
                      "type": "string"
                    },
                    "credits": {
                      "type": "integer"
                    },
                    "model": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required fields"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/moodboard": {
      "get": {
        "tags": ["Moodboard"],
        "summary": "Get moodboard items",
        "description": "Retrieve moodboard items with optional filters",
        "parameters": [
          {
            "name": "itemId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Get specific item by ID"
          },
          {
            "name": "organizationId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by organization ID"
          },
          {
            "name": "brandId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by brand ID"
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by user ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Maximum number of items to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "total": {
                      "type": "integer"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Moodboard"],
        "summary": "Create moodboard item",
        "description": "Save an image to the moodboard collection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["imageUrl", "organizationId"],
                "properties": {
                  "imageUrl": {
                    "type": "string",
                    "description": "URL of the image to save"
                  },
                  "organizationId": {
                    "type": "string",
                    "description": "Organization ID"
                  },
                  "brandId": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string"
                  },
                  "model": {
                    "type": "string"
                  },
                  "aspectRatio": {
                    "type": "string"
                  },
                  "creativeGuideline": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Moodboard item created successfully"
          }
        }
      },
      "put": {
        "tags": ["Moodboard"],
        "summary": "Update moodboard item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["itemId"],
                "properties": {
                  "itemId": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item updated successfully"
          }
        }
      },
      "delete": {
        "tags": ["Moodboard"],
        "summary": "Delete moodboard item(s)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "itemId": {
                    "type": "string"
                  },
                  "itemIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "organizationId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item(s) deleted successfully"
          }
        }
      }
    },
    "/api/meta-campaign": {
      "get": {
        "tags": ["Meta Ads"],
        "summary": "Get Meta campaign analytics",
        "description": "Retrieve Meta (Facebook/Instagram) campaign performance data including ads, metrics, and creative assets",
        "parameters": [
          {
            "name": "metaAccessToken",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Meta API access token"
          },
          {
            "name": "metaAdAccountId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Meta Ad Account ID"
          },
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD)"
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaigns": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string"
                          },
                          "adSets": {
                            "type": "array",
                            "items": {
                              "type": "object"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/brands": {
      "get": {
        "tags": ["Brands"],
        "summary": "Get brands",
        "description": "Retrieve brands for an organization",
        "parameters": [
          {
            "name": "organizationId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Brands retrieved successfully"
          }
        }
      },
      "post": {
        "tags": ["Brands"],
        "summary": "Create brand",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "organizationId"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "organizationId": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Brand created successfully"
          }
        }
      }
    },
    "/api/organizations": {
      "get": {
        "tags": ["Organizations"],
        "summary": "Get organization details",
        "parameters": [
          {
            "name": "organizationId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Organization details retrieved"
          }
        }
      }
    },
    "/api/billing/balance": {
      "get": {
        "tags": ["Billing"],
        "summary": "Get billing balance",
        "description": "Retrieve current credit balance for an organization",
        "parameters": [
          {
            "name": "organizationId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Balance retrieved successfully"
          }
        }
      }
    }
  }
}

