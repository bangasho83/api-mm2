      "get": {"tags": ["Analytics"], "summary": "Get summary statistics", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "brandId", "in": "query", "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
