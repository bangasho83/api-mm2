      "get": {"tags": ["Analytics"], "summary": "Get GA4 users data", "parameters": [{"name": "propertyId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
