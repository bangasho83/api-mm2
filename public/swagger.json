{
  "openapi": "3.0.0",
  "info": {
    "title": "MetrixMate API",
    "description": "API documentation for MetrixMate social media analytics and marketing platform",
    "version": "1.0.0"
  },
  "servers": [
    {"url": "https://api-mm2.vercel.app", "description": "Production server"}
  ],
  "tags": [
    {"name": "Image Generation"},
    {"name": "Moodboard"},
    {"name": "Meta Ads"},
    {"name": "Analytics"},
    {"name": "Billing"},
    {"name": "Organizations"},
    {"name": "Brands"},
    {"name": "Social"},
    {"name": "SEO"},
    {"name": "Keywords"},
    {"name": "Content"},
    {"name": "Sales"},
    {"name": "Users"},
    {"name": "Calendar"},
    {"name": "Utilities"}
  ],
  "paths": {
    "/api/image-gen": {
      "get": {"tags": ["Image Generation"], "summary": "List generated images", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "brandId", "in": "query", "schema": {"type": "string"}}, {"name": "userId", "in": "query", "schema": {"type": "string"}}, {"name": "limit", "in": "query", "schema": {"type": "integer"}}], "responses": {"200": {"description": "Success"}}},
      "post": {"tags": ["Image Generation"], "summary": "Generate images", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["prompt", "organizationId"], "properties": {"prompt": {"type": "string"}, "organizationId": {"type": "string"}, "brandId": {"type": "string"}, "userId": {"type": "string"}, "model": {"type": "string", "enum": ["imagen4", "banana-text", "banana-pro-text", "banana-image", "banana-pro-image", "flux-kontext"]}, "aspect_ratio": {"type": "string", "enum": ["1:1", "16:9", "9:16", "3:4", "4:3"]}, "num_images": {"type": "integer"}, "negative_prompt": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/gen-image-prompt": {
      "post": {"tags": ["Content"], "summary": "Generate image prompt from text", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["prompt"], "properties": {"prompt": {"type": "string"}, "brandGuideline": {"type": "string"}, "creativeGuideline": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/image-prompt": {
      "post": {"tags": ["Content"], "summary": "Generate creative image prompt", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"prompt": {"type": "string"}, "context": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/image-to-prompt": {
      "post": {"tags": ["Content"], "summary": "Generate prompt from image", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["imageUrl"], "properties": {"imageUrl": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/edit-prompt": {
      "post": {"tags": ["Content"], "summary": "Edit and refine prompt", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["prompt", "instruction"], "properties": {"prompt": {"type": "string"}, "instruction": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/moodboard": {
      "get": {"tags": ["Moodboard"], "summary": "Get moodboard items", "parameters": [{"name": "itemId", "in": "query", "schema": {"type": "string"}}, {"name": "organizationId", "in": "query", "schema": {"type": "string"}}, {"name": "brandId", "in": "query", "schema": {"type": "string"}}, {"name": "userId", "in": "query", "schema": {"type": "string"}}, {"name": "limit", "in": "query", "schema": {"type": "integer"}}], "responses": {"200": {"description": "Success"}}},
      "post": {"tags": ["Moodboard"], "summary": "Create moodboard item", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["imageUrl", "organizationId"], "properties": {"imageUrl": {"type": "string"}, "organizationId": {"type": "string"}, "brandId": {"type": "string"}, "userId": {"type": "string"}, "model": {"type": "string"}, "aspectRatio": {"type": "string"}, "note": {"type": "string"}}}}}}, "responses": {"201": {"description": "Created"}}},
      "put": {"tags": ["Moodboard"], "summary": "Update moodboard item", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["itemId"], "properties": {"itemId": {"type": "string"}, "note": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}},
      "delete": {"tags": ["Moodboard"], "summary": "Delete moodboard item(s)", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"itemId": {"type": "string"}, "itemIds": {"type": "array", "items": {"type": "string"}}, "organizationId": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/meta-campaign": {
      "get": {"tags": ["Meta Ads"], "summary": "Get Meta campaign analytics", "parameters": [{"name": "metaAccessToken", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "metaAdAccountId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/meta-ads": {
      "get": {"tags": ["Meta Ads"], "summary": "Get Meta ads data", "parameters": [{"name": "metaAccessToken", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "metaAdAccountId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/meta-stats": {
      "get": {"tags": ["Meta Ads"], "summary": "Get Meta statistics", "parameters": [{"name": "metaAccessToken", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "metaAdAccountId", "in": "query", "required": true, "schema": {"type": "string"}}, {"name": "startDate", "in": "query", "schema": {"type": "string"}}, {"name": "endDate", "in": "query", "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/meta-ad-sim": {
      "post": {"tags": ["Meta Ads"], "summary": "Simulate Meta ad performance", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"adData": {"type": "object"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/brands": {
      "get": {"tags": ["Brands"], "summary": "Get brands", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}},
      "post": {"tags": ["Brands"], "summary": "Create brand", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["name", "organizationId"], "properties": {"name": {"type": "string"}, "organizationId": {"type": "string"}, "description": {"type": "string"}}}}}}, "responses": {"201": {"description": "Created"}}}
    },
    "/api/check-brand": {
      "get": {"tags": ["Brands"], "summary": "Check brand exists", "parameters": [{"name": "brandId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/debug-brand": {
      "get": {"tags": ["Brands"], "summary": "Debug brand data", "parameters": [{"name": "brandId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/organizations": {
      "get": {"tags": ["Organizations"], "summary": "Get organization details", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/balance": {
      "get": {"tags": ["Billing"], "summary": "Get billing balance", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/checkout": {
      "post": {"tags": ["Billing"], "summary": "Create checkout session", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["organizationId"], "properties": {"organizationId": {"type": "string"}, "amount": {"type": "number"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/verify-checkout": {
      "post": {"tags": ["Billing"], "summary": "Verify checkout session", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["sessionId"], "properties": {"sessionId": {"type": "string"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/topup": {
      "post": {"tags": ["Billing"], "summary": "Top up credits", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["organizationId", "amount"], "properties": {"organizationId": {"type": "string"}, "amount": {"type": "number"}}}}}}, "responses": {"200": {"description": "Success"}}}
    },
    "/api/billing/contracts": {
      "get": {"tags": ["Billing"], "summary": "Get billing contracts", "parameters": [{"name": "organizationId", "in": "query", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Success"}}}
    },
